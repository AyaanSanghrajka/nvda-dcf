# --- REQUIRED API KEYS ---

# 1. Finnhub (free stock news API)
#    Sign up at: https://finnhub.io/register
#    Copy your key from: https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key_here

# 2. Anthropic Claude API (for AI summaries)
#    Sign up at: https://console.anthropic.com
#    Create a key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3. Stripe (for payments - optional until you want to charge)
#    Sign up at: https://dashboard.stripe.com/register
#    Find your key at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# 4. Your deployed app URL (update after deploying to Vercel)
VITE_BASE_URL=http://localhost:5173
